;; shadow-cljs pulls its dependencies from deps.edn (:deps true).
{:deps   {:aliases [:dev]}
 :dev-http {8081 "resources/public"}
 :builds
 {:app {:target     :browser
        :output-dir "resources/public/js"
        :asset-path "/js"
        :modules    {:main {:init-fn leonid.core/init}}
        :devtools   {:http-root "resources/public"
                     :http-port 8081}}}}
